{
  "name": "yt-stream-api",
  "version": "1.0.0",
  "description": "YouTube ses stream URL resolver API (yt-dlp tabanli)",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "postinstall": "node -e \"try{require('child_process').execFileSync(require('path').join(__dirname,'node_modules','youtube-dl-exec','bin','yt-dlp'),['-U'],{stdio:'inherit',timeout:30000})}catch(e){console.warn('yt-dlp guncellenemedi, devam ediliyor:',e.message)}\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "node-cache": "^5.1.2",
    "youtube-dl-exec": "^3.0.10"
  }
}
